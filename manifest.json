{
  "name": "PrintRUSH Lopez",
  "short_name": "PrintRUSH",
  "description": "Smart queue management for campus printing shops.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "theme_color": "#0099BB",
  "background_color": "#ffffff",
  "lang": "en-PH",
  "categories": ["productivity", "utilities", "business"],
  "icons": [
    { "src": "/icons/icon.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any maskable" }
